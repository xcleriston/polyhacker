generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("USER")
  active    Boolean  @default(false)
  name      String?
  createdAt DateTime   @default(now())
  traders   Trader[]
  trades    Trade[]
  settings  Settings?
}

model Trader {
  id            String   @id @default(cuid())
  userId        String
  walletAddress String
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, walletAddress])
}

model Trade {
  id              String   @id @default(cuid())
  userId          String
  traderAddress   String
  side            String
  asset           String
  usdcSize        Float
  price           Float
  orderType       String   @default("MARKET")
  status          String   @default("PENDING")
  transactionHash String?
  market          String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id              String   @id @default(cuid())
  userId          String   @unique
  copyMode        String   @default("NORMAL")
  mirrorSizeMode  String   @default("PERCENTAGE")
  fixedAmount     Float    @default(10.0)
  copySize        Float    @default(10.0)
  proxyWallet     String?
  privateKey      String?
  dailyLossCapPct Float    @default(20.0)
  telegramChatId  String?
  testMode        Boolean  @default(true)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

      "regex": "^/api/admin/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/admin/users/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
